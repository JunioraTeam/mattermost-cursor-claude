# standalone | openai | both
# openai = OpenAI-compatible API for mattermost-plugin-agents (blinking caret + tool UI)
# standalone = WebSocket bot only (default)
BOT_MODE=standalone

# Mattermost (required for standalone / both)
MATTERMOST_URL=https://mattermost.example.com
MATTERMOST_BOT_TOKEN=your_personal_access_token
# MATTERMOST_TEAM_ID=
# MATTERMOST_ALLOWED_CHANNEL_IDS=
MATTERMOST_REQUIRE_MENTION=true
MATTERMOST_STREAM_MS=1200
MATTERMOST_MAX_POST_CHARS=15000
MATTERMOST_THREAD_CONTEXT_MAX_CHARS=16000

# OpenAI-compatible API (required for openai / both) — point mattermost-plugin-agents here
# OPENAI_API_PORT=8080
# OPENAI_API_KEY=optional-bearer-secret
# CURSOR_AUTO_APPROVE_REQUESTS=true

# Cursor (cursor-sdk, Python) — see https://cursor.com/docs/sdk/python
CURSOR_API_KEY=
CURSOR_MODEL=composer-2
CURSOR_RUNTIME=cloud
# For local runs:
# CURSOR_RUNTIME=local
# CURSOR_LOCAL_CWD=/workspace

# Cloud agents cannot use stdio MCP (npx/uvx). Use MCP_*_HTTP_URL or MCP_SERVERS_JSON with type "http"/"sse",
# or set CURSOR_RUNTIME=local for stdio presets.

# Cloud agent (GitLab MR / PR via Cursor cloud)
CURSOR_CLOUD_REPOS_JSON=[{"url":"https://gitlab.example.com/group/project.git","startingRef":"develop"}]
CURSOR_CLOUD_AUTO_CREATE_MR=true
CURSOR_CLOUD_SKIP_REVIEWER_REQUEST=true
# CURSOR_CLOUD_ENV_JSON={"GITLAB_TOKEN":"..."}

# MCP — either full JSON or presets (GitLab + Atlassian + optional Figma stdio / HTTP)
# MCP_SERVERS_JSON={"gitlab":{"type":"http","url":"http://gitlab-mcp:3002/mcp","headers":{"Authorization":"Bearer ..."}}}
# MCP_MERGE_PRESETS=true

# Preset: GitLab MCP (https://github.com/zereight/gitlab-mcp)
MCP_GITLAB_COMMAND=npx
MCP_GITLAB_ARGS=-y,@zereight/mcp-gitlab
GITLAB_API_URL=https://gitlab.example.com/api/v4
GITLAB_PERSONAL_ACCESS_TOKEN=
# MR target branch: default develop; never target main or staging
# GITLAB_MR_DEFAULT_TARGET_BRANCH=develop
# GITLAB_MR_FORBIDDEN_TARGET_BRANCHES=main,staging
# Or HTTP transport to zereight/gitlab-mcp container:
# MCP_GITLAB_HTTP_URL=http://gitlab-mcp:3002/mcp
# MCP_GITLAB_HTTP_HEADERS_JSON={"Authorization":"Bearer glpat-..."}

# Preset: Atlassian MCP (https://github.com/sooperset/mcp-atlassian) — self-hosted / DC
MCP_ATLASSIAN_COMMAND=uvx
MCP_ATLASSIAN_ARGS=mcp-atlassian
JIRA_URL=https://jira.example.com
JIRA_PERSONAL_TOKEN=
CONFLUENCE_URL=https://confluence.example.com
CONFLUENCE_PERSONAL_TOKEN=
# Cloud style:
# JIRA_URL=https://company.atlassian.net
# JIRA_USERNAME=you@company.com
# JIRA_API_TOKEN=
# CONFLUENCE_URL=https://company.atlassian.net/wiki
# CONFLUENCE_USERNAME=you@company.com
# CONFLUENCE_API_TOKEN=

# Preset: Framelink Figma MCP (https://github.com/GLips/Figma-Context-MCP)
# https://www.framelink.ai/docs/quickstart — omit token to disable
# FIGMA_PERSONAL_ACCESS_TOKEN=
# MCP_FIGMA_COMMAND=npx
# MCP_FIGMA_ARGS=-y,figma-developer-mcp,--stdio

# Approvals (reply approve TOKEN / deny TOKEN in thread, or HTTP buttons)
APPROVAL_HTTP_PORT=3847
# APPROVAL_PUBLIC_BASE_URL=https://bot.example.com
# APPROVAL_ACTION_SECRET=

# Admin panel (runs + user history); set PANEL_PORT=0 to disable
PANEL_PORT=3850
PANEL_USERNAME=admin
PANEL_PASSWORD=changeme
# PANEL_SECRET=random-string-for-session-cookies

LOG_LEVEL=info
